{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions",
  "windows": ["main"],
    "permissions": [
      "core:default",
      "updater:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/egx-intelligence-api", "sidecar": true }]
    }
  ]
}
